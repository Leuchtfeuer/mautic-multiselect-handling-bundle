{
    "name": "leuchtfeuer/mautic-multiselect-handling",
    "description": "Provides custom campaign and form actions to manage multiselect fields.",
    "license": "GPL-3.0",
    "type": "mautic-plugin",
    "authors": [
        {
          "name": "Leuchtfeuer Digital Marketing GmbH",
          "email": "mautic-plugins@Leuchtfeuer.com",
          "homepage": "https://Leuchtfeuer.com/mautic/",
          "role": "Developer"
        }
      ],
    "keywords": ["mautic","plugin","integration","multiselect"],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "mautic/core-lib": "^7.0",
        "mautic/plugin-social": "*",
        "ext-json": "*"
    },
    "extra": {
        "install-directory-name": "LeuchtfeuerMultiselectHandlingBundle"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.4",
        "symfony/browser-kit": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "MauticPlugin\\LeuchtfeuerMultiselectHandlingBundle\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MauticPlugin\\LeuchtfeuerMultiselectHandlingBundle\\Tests\\": "Tests"
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/mautic/FOSOAuthServerBundle.git"
        },
        {
            "type": "git",
            "url": "https://github.com/mautic/SpBundle.git"
        },
        {
            "type": "git",
            "url": "https://github.com/mautic/SymfonyBridgeBundle.git"
        }
    ],
    "scripts": {
        "cs-fix": "./vendor/bin/php-cs-fixer fix --config .php-cs-fixer.php --using-cache no --show-progress dots -v"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        }
    }
}
